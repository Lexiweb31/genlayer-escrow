# Copy this file to .env and fill in local values. Never commit .env.
# These are server-side Bradbury TESTNET demo signers, not user wallets.
# Configure both keys or neither. Their derived addresses MUST be different.
DEMO_CLIENT_PRIVATE_KEY=0xYOUR_DEMO_CLIENT_PRIVATE_KEY
DEMO_WORKER_PRIVATE_KEY=0xYOUR_DEMO_WORKER_PRIVATE_KEY

# SQLite directory. The local fallback is .data when this is unset.
# On Render, attach a persistent disk first and set this to its mount path,
# for example /var/data/merit.
PERSIST_DATA_DIR=.data

# Optional compatibility key used only by older integration tooling.
# The live dashboard API does not use this key for marketplace actions.
DEPLOYER_PRIVATE_KEY=0xYOUR_LEGACY_TEST_KEY
